#!/usr/bin/env bash
set -euo pipefail

# ─── CLI Flags ────────────────────────────────────────────────────────────────
CHECK_MODE=false
if [[ "${1:-}" == "--check" ]]; then
  CHECK_MODE=true
fi

# ─── Configuration ────────────────────────────────────────────────────────────
# Source a shared config file if it exists. Environment variables already set
# (e.g. via launchd plist) take precedence — the file only fills in gaps.
STATE_DIR="${PR_NOTIFIER_STATE_DIR:-${HOME}/.local/share/pr-notifier}"
CONFIG_FILE="${STATE_DIR}/config"
if [[ -f "$CONFIG_FILE" ]]; then
  set -a
  # shellcheck source=/dev/null
  source "$CONFIG_FILE"
  set +a
fi

# All settings can be overridden via environment variables.
GITHUB_USER="${GITHUB_USER:-}"
GITHUB_ORG="${GITHUB_ORG:-}"
STATE_FILE="${STATE_DIR}/state.json"
LOG_FILE="${STATE_DIR}/pr-notifier.log"
MAX_LOG_LINES="${PR_NOTIFIER_MAX_LOG_LINES:-500}"

# ─── Watched PRs ──────────────────────────────────────────────────────────────
# Monitor PRs with these labels (OR — any label matches).
# Override via PR_NOTIFIER_WATCHED_LABELS (comma-separated).
# Set to empty to disable label watching.
if [[ -n "${PR_NOTIFIER_WATCHED_LABELS+x}" ]]; then
  IFS=',' read -ra WATCHED_LABELS <<< "$PR_NOTIFIER_WATCHED_LABELS"
else
  WATCHED_LABELS=()
fi

# Repos to watch for labeled/review-requested PRs (comma-separated).
# Falls back to legacy PR_NOTIFIER_WATCHED_REPO, then PR_NOTIFIER_WATCHED_ORG.
if [[ -n "${PR_NOTIFIER_WATCHED_REPOS+x}" ]]; then
  IFS=',' read -ra WATCHED_REPOS <<< "$PR_NOTIFIER_WATCHED_REPOS"
elif [[ -n "${PR_NOTIFIER_WATCHED_REPO:-}" ]]; then
  WATCHED_REPOS=("${PR_NOTIFIER_WATCHED_REPO}")
else
  WATCHED_REPOS=()
fi
WATCHED_ORG="${PR_NOTIFIER_WATCHED_ORG:-}"

# Service accounts that are technically "User" type but are automation.
# Add any other non-human accounts here.
IGNORED_USERS=("dependabot[bot]" "github-actions[bot]" "renovate[bot]")

# ─── Helpers ──────────────────────────────────────────────────────────────────

notify() {
  local title="$1"
  local message="$2"
  local url="${3:-}"
  local group="${4:-pr-notifier}"

  if [[ -n "$url" ]] && command -v terminal-notifier &>/dev/null; then
    terminal-notifier -title "$title" -message "$message" -open "$url" -sound Glass -group "$group"
  else
    # Escape double-quotes for osascript
    local t="${title//\"/\\\"}"
    local m="${message//\"/\\\"}"
    osascript -e "display notification \"${m}\" with title \"${t}\" sound name \"Glass\""
  fi

  log "NOTIFY: ${title} — ${message}"
}

log() {
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"
  # Trim log file if too big
  if [[ -f "$LOG_FILE" ]] && (( $(wc -l < "$LOG_FILE") > MAX_LOG_LINES )); then
    tail -n "$MAX_LOG_LINES" "$LOG_FILE" > "${LOG_FILE}.tmp" && mv "${LOG_FILE}.tmp" "$LOG_FILE"
  fi
}

is_ignored_user() {
  local user="$1"
  for ignored in "${IGNORED_USERS[@]}"; do
    if [[ "$user" == "$ignored" ]]; then
      return 0
    fi
  done
  return 1
}

get_state() {
  local key="$1"
  if [[ -f "$STATE_FILE" ]]; then
    jq -r --arg k "$key" '.[$k] // ""' "$STATE_FILE" 2>/dev/null || echo ""
  else
    echo ""
  fi
}

set_state() {
  local key="$1"
  local value="$2"
  if [[ ! -f "$STATE_FILE" ]]; then
    echo '{}' > "$STATE_FILE"
  fi
  local tmp
  tmp=$(jq --arg k "$key" --arg v "$value" '.[$k] = $v' "$STATE_FILE")
  echo "$tmp" > "$STATE_FILE"
}

# ─── Main ─────────────────────────────────────────────────────────────────────

mkdir -p "$STATE_DIR"

if ! command -v gh &>/dev/null; then
  log "ERROR: gh CLI not found"
  exit 1
fi

if ! command -v jq &>/dev/null; then
  log "ERROR: jq not found"
  exit 1
fi

# ─── Check Mode ───────────────────────────────────────────────────────────────
# Usage: pr-notifier --check
# Shows all currently matching watched PRs (labels + review-requested) and sends
# a notification for each one. Does not update state, so normal polling is
# unaffected.

if [[ "$CHECK_MODE" == true ]]; then
  watch_scopes=()
  if (( ${#WATCHED_REPOS[@]} > 0 )); then
    for r in "${WATCHED_REPOS[@]}"; do
      watch_scopes+=("repo:${r}")
    done
  elif [[ -n "$WATCHED_ORG" ]]; then
    watch_scopes=("org:${WATCHED_ORG}")
  fi

  if (( ${#watch_scopes[@]} == 0 )); then
    echo "Error: Set PR_NOTIFIER_WATCHED_REPOS or PR_NOTIFIER_WATCHED_ORG." >&2
    exit 1
  fi

  echo "🔍 Checking watched PRs for ${watch_scopes[*]}..."
  found=0

  # Labeled PRs (OR across labels, union across repos)
  labeled_prs="[]"
  if (( ${#WATCHED_LABELS[@]} > 0 )); then
    echo "   Labels: ${WATCHED_LABELS[*]}"
    for scope in "${watch_scopes[@]}"; do
      for label in "${WATCHED_LABELS[@]}"; do
        result=$(gh api -X GET "search/issues" \
          -f q="is:pr is:open ${scope} label:\"${label}\"" \
          -f per_page=50 \
          --jq '[.items[] | {
            number: .number,
            title: .title,
            url: .html_url,
            repo: (.repository_url | split("/") | .[-2] + "/" + .[-1])
          }]' \
          2>/dev/null || echo "[]")
        labeled_prs=$(echo "${labeled_prs}" "${result}" | jq -s 'add | unique_by("\(.repo)#\(.number)")')
      done
    done

    label_count=$(echo "$labeled_prs" | jq 'length')
    echo "   Found ${label_count} labeled PR(s)"
    echo "$labeled_prs" | jq -c '.[]' | while IFS= read -r pr; do
      num=$(echo "$pr" | jq -r '.number')
      pr_title=$(echo "$pr" | jq -r '.title')
      pr_url=$(echo "$pr" | jq -r '.url')
      short_repo=$(echo "$pr" | jq -r '.repo' | cut -d/ -f2)
      echo "   🏷️  ${short_repo}#${num}: ${pr_title}"
      notify "🏷️ Design Review — ${short_repo}#${num}" "${pr_title}" "$pr_url" "pr-${short_repo}-${num}"
    done
    found=$((found + label_count))
  fi

  # Review-requested PRs
  if [[ -n "$GITHUB_USER" ]]; then
    echo "   Review requested for: ${GITHUB_USER}"
    review_prs="[]"
    for scope in "${watch_scopes[@]}"; do
      result=$(gh api -X GET "search/issues" \
        -f q="is:pr is:open ${scope} review-requested:${GITHUB_USER}" \
        -f per_page=50 \
        --jq '[.items[] | {
          number: .number,
          title: .title,
          url: .html_url,
          repo: (.repository_url | split("/") | .[-2] + "/" + .[-1])
        }]' \
        2>/dev/null || echo "[]")
      review_prs=$(echo "${review_prs}" "${result}" | jq -s 'add | unique_by("\(.repo)#\(.number)")')
    done

    review_count=$(echo "$review_prs" | jq 'length')
    echo "   Found ${review_count} review-requested PR(s)"
    echo "$review_prs" | jq -c '.[]' | while IFS= read -r pr; do
      num=$(echo "$pr" | jq -r '.number')
      pr_title=$(echo "$pr" | jq -r '.title')
      pr_url=$(echo "$pr" | jq -r '.url')
      short_repo=$(echo "$pr" | jq -r '.repo' | cut -d/ -f2)
      echo "   👀 ${short_repo}#${num}: ${pr_title}"
      notify "👀 Review Requested — ${short_repo}#${num}" "${pr_title}" "$pr_url" "pr-${short_repo}-${num}"
    done
    found=$((found + review_count))
  fi

  echo "✅ Done. ${found} total PR(s) found."
  exit 0
fi

# ─── Normal Poll Mode ────────────────────────────────────────────────────────

log "Starting poll cycle for org: ${GITHUB_ORG}"

# Single API call to find all open PRs authored by us across the entire org.
# This avoids iterating 100+ repos individually.
# -X GET is required so gh sends the params as query parameters, not a POST body.
search_json=$(gh api -X GET "search/issues" \
  -f q="is:pr is:open author:${GITHUB_USER} org:${GITHUB_ORG}" \
  -f per_page=50 \
  --jq '[.items[] | {
    number: .number,
    title: .title,
    url: .html_url,
    repo: (.repository_url | split("/") | .[-2] + "/" + .[-1]),
    is_draft: .draft
  }]' \
  2>/dev/null || echo "[]")

pr_count=$(echo "$search_json" | jq 'length')
log "Found ${pr_count} open PRs across ${GITHUB_ORG}"

echo "$search_json" | jq -c '.[]' | while IFS= read -r pr; do
  repo=$(echo "$pr" | jq -r '.repo')
  pr_number=$(echo "$pr" | jq -r '.number')
  pr_title=$(echo "$pr" | jq -r '.title')
  pr_url=$(echo "$pr" | jq -r '.url')
  is_draft=$(echo "$pr" | jq -r '.is_draft')
  state_prefix="${repo}#${pr_number}"

  # Get full PR details including CI status (search API doesn't include these).
  # statusCheckRollup includes both CheckRun and StatusContext items, unlike
  # `gh pr checks` which only returns CheckRun and silently drops commit statuses.
  full_pr=$(gh pr view "$pr_number" \
    --repo "$repo" \
    --json headRefOid,reviewDecision,isDraft,statusCheckRollup \
    2>/dev/null || echo '{}')

  head_sha=$(echo "$full_pr" | jq -r '.headRefOid // ""')
  review_decision=$(echo "$full_pr" | jq -r '.reviewDecision // ""')
  is_draft=$(echo "$full_pr" | jq -r '.isDraft // false')

  if [[ -z "$head_sha" ]]; then
    log "Skipping PR #${pr_number} in ${repo}: could not fetch details"
    continue
  fi

  log "Processing ${repo}#${pr_number}: ${pr_title} (sha: ${head_sha:0:8})"

  # ── 1. Check CI status ──────────────────────────────────────────────────
  # Normalize CheckRun and StatusContext into a unified format:
  #   CheckRun:      { name, status: "COMPLETED", conclusion: "SUCCESS"|"FAILURE"|... }
  #   StatusContext:  { context (as name), state: "SUCCESS"|"FAILURE"|"PENDING" }
  checks_json=$(echo "$full_pr" | jq '[
    (.statusCheckRollup // [])[] |
    if .__typename == "CheckRun" then
      { name: .name, status: .status, conclusion: .conclusion }
    else
      {
        name: .context,
        status: (if .state == "PENDING" then "IN_PROGRESS" else "COMPLETED" end),
        conclusion: (if .state == "SUCCESS" then "SUCCESS"
                     elif .state == "FAILURE" or .state == "ERROR" then "FAILURE"
                     else "" end)
      }
    end
  ]')

  total_checks=$(echo "$checks_json" | jq 'length')
  completed_checks=$(echo "$checks_json" | jq '[.[] | select(.status == "COMPLETED")] | length')
  failed_checks=$(echo "$checks_json" | jq '[.[] | select(.conclusion == "FAILURE" or .conclusion == "STARTUP_FAILURE" or .conclusion == "TIMED_OUT")] | length')

  prev_sha=$(get_state "${state_prefix}_sha")
  prev_ci_state=$(get_state "${state_prefix}_ci_state")

  # Determine current CI state
  if (( total_checks == 0 )); then
    ci_state="none"
  elif (( failed_checks > 0 )); then
    ci_state="failed"
  elif (( completed_checks == total_checks )); then
    ci_state="passed"
  else
    ci_state="pending"
  fi

  # Short repo name for notifications
  short_repo=$(echo "$repo" | cut -d/ -f2)

  # Notify on CI failure (immediately, even if not all checks done)
  if [[ "$ci_state" == "failed" && "$prev_ci_state" != "failed" && "$head_sha" == "$prev_sha" ]]; then
    failed_names=$(echo "$checks_json" | jq -r '[.[] | select(.conclusion == "FAILURE" or .conclusion == "STARTUP_FAILURE" or .conclusion == "TIMED_OUT")] | .[0:3] | .[].name' | tr '\n' ', ' | sed 's/,$//')
    notify "❌ CI Failed — ${short_repo}#${pr_number}" "${failed_names}" "$pr_url" "pr-${pr_number}"
  fi

  # New push — reset CI tracking
  if [[ "$head_sha" != "$prev_sha" ]]; then
    log "New SHA detected for ${repo}#${pr_number}, resetting CI state"
    set_state "${state_prefix}_sha" "$head_sha"
    set_state "${state_prefix}_ci_state" "$ci_state"
    if [[ "$ci_state" == "failed" ]]; then
      failed_names=$(echo "$checks_json" | jq -r '[.[] | select(.conclusion == "FAILURE" or .conclusion == "STARTUP_FAILURE" or .conclusion == "TIMED_OUT")] | .[0:3] | .[].name' | tr '\n' ', ' | sed 's/,$//')
      notify "❌ CI Failed — ${short_repo}#${pr_number}" "${failed_names}" "$pr_url" "pr-${pr_number}"
    fi
  else
    # Same SHA — check for transitions
    if [[ "$ci_state" == "passed" && "$prev_ci_state" != "passed" ]]; then
      notify "✅ CI Passed — ${short_repo}#${pr_number}" "${pr_title}" "$pr_url" "pr-${pr_number}"
    fi
    set_state "${state_prefix}_ci_state" "$ci_state"
  fi

  # ── 2. Check for new human reviews (changes_requested or commented) ─────
  reviews_json=$(gh api "repos/${repo}/pulls/${pr_number}/reviews" \
    --jq '[.[] | select(.user.type != "Bot") | {id: .id, user: .user.login, state: .state}]' \
    2>/dev/null || echo "[]")

  latest_review_id=$(echo "$reviews_json" | jq -r 'if length > 0 then .[-1].id else 0 end')
  prev_review_id=$(get_state "${state_prefix}_last_review_id")
  prev_review_id=${prev_review_id:-0}

  if (( latest_review_id > prev_review_id )); then
    new_reviews=$(echo "$reviews_json" | jq -c --argjson prev "$prev_review_id" '[.[] | select(.id > $prev)]')
    echo "$new_reviews" | jq -c '.[]' 2>/dev/null | while IFS= read -r review; do
      reviewer=$(echo "$review" | jq -r '.user')
      review_state=$(echo "$review" | jq -r '.state')

      if [[ "$review_state" == "APPROVED" ]]; then
        continue
      fi

      if [[ "$reviewer" == "$GITHUB_USER" ]] || is_ignored_user "$reviewer"; then
        continue
      fi

      case "$review_state" in
        CHANGES_REQUESTED)
          notify "🔃 Changes Requested — ${short_repo}#${pr_number}" "${reviewer} requested changes" "$pr_url" "pr-${pr_number}"
          ;;
        COMMENTED)
          notify "💬 Review Comment — ${short_repo}#${pr_number}" "${reviewer} left a review" "$pr_url" "pr-${pr_number}"
          ;;
      esac
    done
    set_state "${state_prefix}_last_review_id" "$latest_review_id"
  fi

  # ── 3. Check for new issue comments (non-bot, non-self) ─────────────────
  comments_json=$(gh api "repos/${repo}/issues/${pr_number}/comments" \
    --jq '[.[] | select(.user.type != "Bot") | select(.user.login != "'"$GITHUB_USER"'") | {id: .id, user: .user.login, body: (.body | split("\n") | .[0] | .[0:120])}]' \
    2>/dev/null || echo "[]")

  latest_comment_id=$(echo "$comments_json" | jq -r 'if length > 0 then .[-1].id else 0 end')
  prev_comment_id=$(get_state "${state_prefix}_last_comment_id")
  prev_comment_id=${prev_comment_id:-0}

  if (( latest_comment_id > prev_comment_id )); then
    new_comments=$(echo "$comments_json" | jq -c --argjson prev "$prev_comment_id" '[.[] | select(.id > $prev)]')
    echo "$new_comments" | jq -c '.[]' 2>/dev/null | while IFS= read -r comment; do
      commenter=$(echo "$comment" | jq -r '.user')
      if is_ignored_user "$commenter"; then
        continue
      fi
      body=$(echo "$comment" | jq -r '.body')
      notify "💬 Comment — ${short_repo}#${pr_number}" "${commenter}: ${body}" "$pr_url" "pr-${pr_number}"
    done
    set_state "${state_prefix}_last_comment_id" "$latest_comment_id"
  fi

  # ── 4. Ready to merge detection ─────────────────────────────────────────
  prev_ready=$(get_state "${state_prefix}_ready_to_merge")
  is_ready="false"

  if [[ "$is_draft" == "false" && "$ci_state" == "passed" && "$review_decision" == "APPROVED" ]]; then
    is_ready="true"
  fi

  if [[ "$is_ready" == "true" && "$prev_ready" != "true" ]]; then
    notify "🚀 Ready to Merge! — ${short_repo}#${pr_number}" "${pr_title}" "$pr_url" "pr-${pr_number}"
  fi
  set_state "${state_prefix}_ready_to_merge" "$is_ready"

done

# ─── 5. Watched PRs: label + review-requested monitoring ─────────────────────

watch_scopes=()
if (( ${#WATCHED_REPOS[@]} > 0 )); then
  for r in "${WATCHED_REPOS[@]}"; do
    watch_scopes+=("repo:${r}")
  done
elif [[ -n "$WATCHED_ORG" ]]; then
  watch_scopes=("org:${WATCHED_ORG}")
fi

if (( ${#watch_scopes[@]} > 0 )); then

  # ── 5a. Query for labeled PRs (OR across labels, union across repos) ────
  labeled_prs="[]"
  if (( ${#WATCHED_LABELS[@]} > 0 )); then
    for scope in "${watch_scopes[@]}"; do
      for label in "${WATCHED_LABELS[@]}"; do
        result=$(gh api -X GET "search/issues" \
          -f q="is:pr is:open ${scope} label:\"${label}\"" \
          -f per_page=50 \
          --jq '[.items[] | {
            number: .number,
            title: .title,
            url: .html_url,
            repo: (.repository_url | split("/") | .[-2] + "/" + .[-1])
          }]' \
          2>/dev/null || echo "[]")
        labeled_prs=$(echo "${labeled_prs}" "${result}" | jq -s 'add | unique_by("\(.repo)#\(.number)")')
      done
    done
    log "Watched labels: found $(echo "$labeled_prs" | jq 'length') open PRs"
  fi

  # ── 5b. Query for review-requested PRs ────────────────────────────────────
  review_prs="[]"
  for scope in "${watch_scopes[@]}"; do
    result=$(gh api -X GET "search/issues" \
      -f q="is:pr is:open ${scope} review-requested:${GITHUB_USER}" \
      -f per_page=50 \
      --jq '[.items[] | {
        number: .number,
        title: .title,
        url: .html_url,
        repo: (.repository_url | split("/") | .[-2] + "/" + .[-1])
      }]' \
      2>/dev/null || echo "[]")
    review_prs=$(echo "${review_prs}" "${result}" | jq -s 'add | unique_by("\(.repo)#\(.number)")')
  done
  log "Watched review-requested: found $(echo "$review_prs" | jq 'length') open PRs"

  # ── 5c. Compare with previous state and notify ────────────────────────────

  prev_labeled=$(get_state "watched_labeled_prs")
  prev_labeled=${prev_labeled:-"[]"}
  prev_review=$(get_state "watched_review_prs")
  prev_review=${prev_review:-"[]"}

  prev_labeled_keys=$(echo "$prev_labeled" | jq '[.[] | "\(.repo)#\(.number)"]')
  prev_review_keys=$(echo "$prev_review" | jq '[.[] | "\(.repo)#\(.number)"]')

  # New labeled PRs
  echo "$labeled_prs" | jq -c '.[]' | while IFS= read -r pr; do
    num=$(echo "$pr" | jq -r '.number')
    repo=$(echo "$pr" | jq -r '.repo')
    key="${repo}#${num}"
    if ! echo "$prev_labeled_keys" | jq -e "index(\"${key}\")" &>/dev/null; then
      pr_title=$(echo "$pr" | jq -r '.title')
      pr_url=$(echo "$pr" | jq -r '.url')
      short_repo=$(echo "$repo" | cut -d/ -f2)
      notify "🏷️ Design Review — ${short_repo}#${num}" "${pr_title}" "$pr_url" "pr-${short_repo}-${num}"
    fi
  done

  # New review-requested PRs
  echo "$review_prs" | jq -c '.[]' | while IFS= read -r pr; do
    num=$(echo "$pr" | jq -r '.number')
    repo=$(echo "$pr" | jq -r '.repo')
    key="${repo}#${num}"
    if ! echo "$prev_review_keys" | jq -e "index(\"${key}\")" &>/dev/null; then
      pr_title=$(echo "$pr" | jq -r '.title')
      pr_url=$(echo "$pr" | jq -r '.url')
      short_repo=$(echo "$repo" | cut -d/ -f2)
      notify "👀 Review Requested — ${short_repo}#${num}" "${pr_title}" "$pr_url" "pr-${short_repo}-${num}"
    fi
  done

  # ── 5d. Closure/merge detection ───────────────────────────────────────────
  # Union previous labeled + review sets, compare with current union.
  # PRs that disappeared might be closed/merged.

  prev_all=$(echo "$prev_labeled" "$prev_review" | jq -s 'add | unique_by("\(.repo)#\(.number)")')
  curr_all=$(echo "$labeled_prs" "$review_prs" | jq -s 'add | unique_by("\(.repo)#\(.number)")')
  curr_all_keys=$(echo "$curr_all" | jq '[.[] | "\(.repo)#\(.number)"]')

  echo "$prev_all" | jq -c '.[]' | while IFS= read -r pr; do
    num=$(echo "$pr" | jq -r '.number')
    repo=$(echo "$pr" | jq -r '.repo')
    key="${repo}#${num}"
    if ! echo "$curr_all_keys" | jq -e "index(\"${key}\")" &>/dev/null; then
      pr_title=$(echo "$pr" | jq -r '.title')
      pr_url=$(echo "$pr" | jq -r '.url')
      short_repo=$(echo "$repo" | cut -d/ -f2)

      # Check if the PR was closed/merged (not just unlabeled)
      pr_state=$(gh pr view "$num" --repo "$repo" --json state --jq '.state' 2>/dev/null || echo "UNKNOWN")

      if [[ "$pr_state" == "CLOSED" || "$pr_state" == "MERGED" ]]; then
        state_emoji="✅"
        [[ "$pr_state" == "MERGED" ]] && state_emoji="🎉"
        notify "${state_emoji} PR ${pr_state} — ${short_repo}#${num}" "${pr_title}" "$pr_url" "pr-${short_repo}-${num}"
      else
        log "PR ${repo}#${num} left watched set (label removed or review dismissed)"
      fi
    fi
  done

  # ── 5e. Update state ──────────────────────────────────────────────────────
  set_state "watched_labeled_prs" "$(echo "$labeled_prs" | jq -c '.')"
  set_state "watched_review_prs" "$(echo "$review_prs" | jq -c '.')"

fi

log "Poll cycle complete"
